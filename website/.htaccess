# ── PolyForge – Clean URLs (hide .html extension) ──
# Place this file in the web root on cPanel/Apache

RewriteEngine On

# Redirect .html requests to extensionless URLs (301 permanent)
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# Serve the .html file internally when extensionless URL is requested
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]
