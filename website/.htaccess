# ── PolyForge – Clean URLs + hardening ──
# Place this file in the web root on cPanel/Apache

AddDefaultCharset utf-8
Options -Indexes
DirectoryIndex index.php
ErrorDocument 404 /404.php

RewriteEngine On

# Never serve the shared partials directly
RewriteRule ^partials(/|$) - [F,L]

# security-reports/ holds admin-uploaded evidence (screenshots/PDFs) — static
# content only; never let anything in there execute even if it slipped past the
# upload extension whitelist.
RewriteRule ^security-reports/.+\.(php|phtml|phar)$ - [F,L]

# Data files are only accessed through their API endpoints
<FilesMatch "^(tetris-scores\.json|pack-access-state\.json|stats-data\.json|packs-data\.json|admin-state\.json|manifest-history\.json|security-data\.json|packs\.data\.php|packs-registry\.php|admin-config\.php|slime-lib\.php|security-lib\.php|virustotal\.php|php-compat\.php)$">
  Require all denied
</FilesMatch>

# .polypack files are downloads, not executables — serve as a binary blob
<FilesMatch "\.polypack$">
  ForceType application/octet-stream
</FilesMatch>

# PowerShell tools (e.g. tools/package-modpack.ps1) are downloads, not text to
# render inline — force a save dialog instead of showing the source.
<FilesMatch "\.ps1$">
  ForceType application/octet-stream
  <IfModule mod_headers.c>
    Header set Content-Disposition "attachment"
  </IfModule>
</FilesMatch>

# /index, /index.html, /index.php → / (301 permanent)
RewriteCond %{THE_REQUEST} \s/+index(?:\.(?:html|php))?[\s?] [NC]
RewriteRule ^ / [R=301,L]

# Redirect legacy .html and direct .php requests to extensionless URLs (301 permanent)
RewriteCond %{THE_REQUEST} \s/+(.+?)\.(?:html|php)[\s?] [NC]
RewriteRule ^ /%1 [R=301,L,NE]

# Serve the .php file internally when an extensionless URL is requested
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+)$ $1.php [L]

# ── Security headers ──
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

# ── Static asset caching ──
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/png "access plus 30 days"
  ExpiresByType image/x-icon "access plus 30 days"
  ExpiresByType text/css "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
  # stats.json is polled by the site; keep it fresh
  ExpiresByType application/json "access plus 5 minutes"
</IfModule>
